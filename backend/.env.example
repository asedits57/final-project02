PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database
APP_URL=http://localhost:8080
# For local fallback-only development, you can use:
# MONGO_URI=memory
# Optional: force MongoMemoryServer files into a writable folder, e.g.:
# MONGO_MEMORY_ROOT=D:\final-project02-mongo-memory
# Optional: point to a known-good mongod binary if auto-detection is not enough
# MONGO_MEMORY_BINARY=C:\Users\YourName\.cache\mongodb-binaries\mongod-x64-win32-8.2.1.exe
# Optional for test/CI stability:
# TEST_MONGO_URI=mongodb://127.0.0.1:27017/final-project02-test
# MONGO_MEMORY_ALLOW_DOWNLOAD=false
JWT_SECRET=your_jwt_secret_key_here
OTP_HASH_SECRET=your_otp_hash_secret_here
OTP_MAX_ATTEMPTS=5
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me
ADMIN_BOOTSTRAP_NAME=Admin User

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_REDIRECT_URI=http://localhost:8080/auth/github/callback

# Email provider
EMAIL_PROVIDER=resend
EMAIL_FROM=MEC Learning <onboarding@resend.dev>
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Optional alternative provider that can be used instead of Resend
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=YOUR_BREVO_API_KEY
# Optional: enable Redis caching only when you have a running Redis instance
# REDIS_URL=redis://127.0.0.1:6379

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

